@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudText Typo="Typo.h6">FSBS</MudText>
        <MudSpacer />
        <MudButton Color="Color.Inherit" Href="/dashboard" Variant="Variant.Text">Dashboard</MudButton>
        <MudButton Color="Color.Inherit" Href="/availability" Variant="Variant.Text">Book</MudButton>
        <MudButton Color="Color.Inherit" Href="/my-bookings" Variant="Variant.Text">My Bookings</MudButton>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudTooltip Text="Profile">
                    <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" Href="/profile" />
                </MudTooltip>
                <MudTooltip Text="Sign out">
                    <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" Href="/logout" />
                </MudTooltip>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 pa-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
