@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Transparent">
        <MudText Typo="Typo.h6" Color="Color.Primary">FSBS</MudText>
        <MudSpacer />
        <MudButton Href="/login" Color="Color.Primary" Variant="Variant.Text">Sign In</MudButton>
        <MudButton Href="/register" Color="Color.Primary" Variant="Variant.Filled" Class="ml-2">Register</MudButton>
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-16 pa-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
