@page "/login"
@layout PublicLayout
@inject IConfiguration Config
@inject NavigationManager Nav

<PageTitle>Sign In — FSBS</PageTitle>

<MudText Typo="Typo.h4" Align="Align.Center" Class="mb-2">Customer Sign In</MudText>
<MudText Align="Align.Center" Color="Color.Secondary" Class="mb-6">
    Sign in with your FSBS customer account.
</MudText>

@if (_confirmed)
{
    <MudAlert Severity="Severity.Success" Dense="true" Class="mb-4">
        Account confirmed! You can now sign in.
    </MudAlert>
}

<MudPaper Elevation="3" Class="pa-8">
    @if (_isDev)
    {
        <MudButton FullWidth="true"
                   Variant="Variant.Filled"
                   Color="Color.Warning"
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.DeveloperMode"
                   Href="/dev/login"
                   Class="mb-4">
            Dev Sign In (pick any role)
        </MudButton>
        <MudDivider Class="mb-4" />
    }

    <MudButton FullWidth="true"
               Variant="Variant.Filled"
               Color="Color.Primary"
               Size="Size.Large"
               StartIcon="@Icons.Material.Filled.Login"
               Href="@_loginUrl"
               Disabled="@string.IsNullOrWhiteSpace(_loginUrl)">
        Continue to Sign In
    </MudButton>

    <MudDivider Class="my-6" />

    <MudStack Spacing="1" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.body2">
            New customer? <MudLink Href="/register">Create an account</MudLink>
        </MudText>
        <MudText Typo="Typo.body2">
            Have an invitation? <MudLink Href="/invitations/claim">Claim it here</MudLink>
        </MudText>
        <MudText Typo="Typo.body2">
            FSBS staff? <MudLink Href="/login/staff">Staff sign in</MudLink>
        </MudText>
    </MudStack>
</MudPaper>

@code {
    [SupplyParameterFromQuery(Name = "confirmed")]
    public bool? Confirmed { get; set; }

    private string _loginUrl = "#";
    private bool _isDev;
    private bool _confirmed;

    protected override void OnInitialized()
    {
        _loginUrl  = Config["Cognito:CustomerPoolLoginUrl"] ?? string.Empty;
        _confirmed = Confirmed == true;
        _isDev     = Nav.BaseUri.Contains("localhost", StringComparison.OrdinalIgnoreCase) ||
                     Nav.BaseUri.Contains("127.0.0.1", StringComparison.OrdinalIgnoreCase);
    }
}
